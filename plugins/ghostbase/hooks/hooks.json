{
  "description": "Ghostbase lifecycle hooks",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/log-stop-session.mjs\"",
            "timeout": 30,
            "async": true
          }
        ]
      }
    ]
  }
}
